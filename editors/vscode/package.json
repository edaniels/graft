{
  "name": "graft",
  "displayName": "Graft Dev",
  "description": "Your local environment, everywhere.",
  "version": "0.1.3",
  "publisher": "ericdaniels",
  "author": "Eric Daniels",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "homepage": "https://graft.run",
  "repository": {
    "type": "git",
    "url": "https://github.com/edaniels/graft",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/edaniels/graft/issues"
  },
  "keywords": [
    "remote",
    "development",
    "ssh",
    "docker",
    "terminal",
    "graft"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "graft.selectConnection",
        "title": "Select Connection",
        "category": "Graft"
      },
      {
        "command": "graft.openTerminal",
        "title": "Open Terminal to Connection",
        "category": "Graft"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "id": "graft.terminal",
          "title": "Graft Remote Terminal"
        }
      ]
    },
    "configuration": {
      "title": "Graft",
      "properties": {
        "graft.executablePath": {
          "type": "string",
          "default": "",
          "description": "Path to the graft executable. If empty, resolved via the login shell.",
          "scope": "machine-overridable"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
